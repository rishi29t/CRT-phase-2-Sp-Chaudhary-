Problem : 28 
Approach 1 : using find function in string . 
class Solution {
public:
    int strStr(string haystack, string needle) {
        if(haystack.find(needle)==haystack.npos){
            return -1;
        }
        else{
            return haystack.find(needle);
        }
    }
};

Problem : 643 
maximum avg of sub array 
class Solution {
public:
    double findMaxAverage(vector<int>& arr, int k) {
        int left =0 , right=0;
        double sum=0;
        double avg = INT_MIN;
        while(right < arr.size()){
            sum+=arr[right];
            if(right-left+1 ==k){
                avg=max(sum/k,avg);
                sum-=arr[left];
                left++;
            }
            right++;
        }
        return avg;
    }
};
