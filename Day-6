class Solution {
    static bool help(ListNode *a,ListNode *b){
        return a->val< b->val;
    }
public:
   ListNode* sortList(ListNode *head){
    if(head == nullptr)
        return head;
    vector<ListNode*> arr;
    while(head!=nullptr){
        arr.push_back(head);
        head=head->next;
    }
    sort(arr.begin(),arr.end(),help);
    for(int i=0; i<arr.size()-1;i++){
        arr[i]->next = arr[i+1];
    }
    arr[arr.size()-1]->next = nullptr;
    return arr[0];
   }
};
