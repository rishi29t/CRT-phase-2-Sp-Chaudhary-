        left[i]=max(height[i-1],left[i-1]);
      }  
      //right max->
      int count=0;
      int right=height[n-1];
      for(int i=n-2;i>=0;i--){
        if(left[i]>height[i] && right>height[i]){
            count+=min(left[i],right)-height[i];
        }
        right=max(height[i],right);
      }
      return count;
    }
};
LeetCode : 94 
int order traversal 
class Solution {
public:
    void traversal(TreeNode* root, vector<int>& ans){
    // Base condition 
    if( root == nullptr){
        return;
    }
    // Logical 
    traversal(root->left,ans);
    ans.push_back(root->val);
    traversal(root->right,ans);
    }
    vector<int> inorderTraversal(TreeNode* root) {
     vector<int>ans;
     traversal(root,ans);
     return ans;   
    }
};
