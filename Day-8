class Solution {
    vector<int>arr;
public:
    Solution(ListNode* head) {
        while(head){
            arr.push_back(head->val);
            head=head->next;
        }
    } 
    int getRandom() {
     int randIndex=rand()%arr.size();
     return arr[randIndex];   
    }
};
