class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& arr1, vector<int>& arr2) {
        unordered_map<int,int> map;
        stack<int>stk;
        for(int i=arr2.size()-1; i>=0; i--){
            while(!stk.empty() && stk.top()<=arr2[i]){
                stk.pop();
            }
            map[arr2[i]]= stk.empty() ? -1: stk.top();
            stk.push(arr2[i]);
        }
        vector<int> ans;
        for(int i=0 ; i<arr1.size();i++){
            ans.push_back(map[arr1[i]]);
        }
        return ans;
    }
};
