Leet code : 86 
partition list 
class Solution {
public:
    ListNode* partition(ListNode* head, int x) {
      ListNode dummy1,dummy2;
      ListNode *p1=&dummy1, *p2=&dummy2;
      while(head){
        if(head->val <x){
            p1->next=head;
            p1=p1->next;
        }
        else{
            p2->next = head;
            p2=p2->next;
        }
        head=head->next;
      }  
      p1->next= dummy2.next;
      p2->next=nullptr;
      return dummy1.next;
    }
};
Leetcode : 234 Palindrome linked list using stack 
class Solution {
    ListNode* midNode(ListNode* head){
        ListNode *slow=head, *fast=head;
        while(fast->next!=nullptr && fast->next->next!=nullptr){
            slow=slow->next;
            fast=fast->next->next;
        }
        return slow;
    }
public:
    bool isPalindrome(ListNode* head) {

        ListNode *mid = midNode(head);
        ListNode *ptr = mid->next;
        mid->next=nullptr;
        stack<int> stk;
        while(ptr){
            stk.push(ptr->val);
            ptr=ptr->next;
        }
        while(!stk.empty()){
            if(stk.top()!=head->val)
                return false;
            head=head->next;
            stk.pop();
        }
        return true;
    }
};
